    "poker-table": {
      "path": "contracts/poker-table/src",
      "key_enums": ["DataKey"],
      "literal_keys": ["Symbol::next_id"],
      "sensitive_writes": {
        "DataKey::Table": {
          "authorized_functions": [
            "create_table",
            "join_table",
            "leave_table",
            "start_hand",
            "commit_deal",
            "player_action",
            "reveal_board",
            "submit_showdown",
            "claim_timeout",
            "set_hub",
            "set_rake_bps",
            "set_min_players",
            "withdraw_rake"
          ],
          "auth_model": "player_or_committee_or_admin_require_auth",
          "admin_multisig_required": true
        },
        "DataKey::Paused": {
          "authorized_functions": ["pause", "unpause"],
          "auth_model": "table_admin_require_auth",
          "admin_multisig_required": true
        },
        "Symbol::next_id": {
          "authorized_functions": ["create_table"],
          "auth_model": "creator_admin_require_auth",
          "admin_multisig_required": true
        }
      }
    },
